<p style="color: green"><%= notice %></p>

<% content_for :title, "Posts" %>

<h1>⚡ Hotwire Blog</h1>

<div class="row mt-4">

  <%# LEFT — Form column %>
  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <h5>✍️ New Post</h5>

        <%# ✅ id="post_form" — turbo stream target %>
        <div id="post_form">
          <%= render "form", post: Post.new %>
        </div>

      </div>
    </div>
  </div>
  <div class="col-md-8">
    <%# ✅ Subscribe to posts channel %>
    <%= turbo_stream_from "posts" %>
    
    <%# Posts list — target for broadcasts %>
    <div class="row" id="posts_list">
      <% @posts.each do |post| %>
        <%= render post %>
      <% end %>
    </div>
  </div>

<%= link_to "New post", new_post_path %>
